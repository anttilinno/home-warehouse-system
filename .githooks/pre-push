#!/usr/bin/env bash
# Pre-push quality gate.
#
# Mirrors the SonarQube rules that matter — backend: golangci-lint
# (gocognit/goconst/dupl/gosec, see backend/.golangci.yml); frontend: biome +
# tsc. Runs only for the part of the tree that changed relative to
# origin/master, and golangci uses --new-from-merge-base so it blocks NEW
# regressions without flagging the legacy backlog.
#
# Enable once:  git config core.hooksPath .githooks   (done by `mise run setup`)
# Bypass once:  git push --no-verify
set -uo pipefail

REMOTE_BASE="origin/master"
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

# Need the base ref to compute "new" code. If missing (offline / fresh clone),
# skip rather than block or flag the whole legacy tree.
if ! git rev-parse --verify --quiet "$REMOTE_BASE" >/dev/null; then
  echo "pre-push: $REMOTE_BASE not found locally — skipping quality gate." >&2
  exit 0
fi

BASE="$(git merge-base "$REMOTE_BASE" HEAD)"
CHANGED="$(git diff --name-only "$BASE"...HEAD)"
fail=0

if grep -q '^backend/' <<<"$CHANGED"; then
  echo "pre-push: backend changed — golangci-lint (new code) + go build…"
  (
    cd backend || exit 1
    golangci-lint run --new-from-merge-base="$REMOTE_BASE" ./... || exit 1
    go build ./... || exit 1
  ) || fail=1
fi

if grep -q '^frontend/' <<<"$CHANGED"; then
  echo "pre-push: frontend changed — biome lint + tsc + complexity + dup…"
  (
    cd frontend || exit 1
    # Gate on biome ERRORS (correctness) only — pre-existing style warnings
    # must not block pushes.
    bunx biome lint --diagnostic-level=error src || exit 1
    bun run lint:tsc || exit 1
    # Complexity gate (cyclomatic + cognitive, threshold 15). The whole tree is
    # at zero offenders, so the config ERRORS on any regression anywhere. Mirrors
    # the backend gocognit/gocyclo gate.
    bun run lint:complexity || exit 1
    # Dead-code gate (knip). Scoped to high-signal categories — unused FILES +
    # dependency drift (unused/unlisted/unresolved/binaries); the noisy
    # barrel-export reporting is off (see knip.json rules). The tree is clean,
    # so a newly-orphaned file or a stray dep blocks. `lint:dead` (same command)
    # is the on-demand report.
    bun run lint:dead || exit 1
    # Duplication ceiling (dupl analog). jscpd can't gate per-file (it globs
    # within paths, so a file list scans nothing), so this is a whole-tree
    # CEILING rather than a strict new-from-base diff: the current tree sits
    # just under 4%, so legacy never trips it but a real duplication regression
    # does. `lint:dup` (no threshold) prints the full clone report on demand.
    ./node_modules/.bin/jscpd src --threshold 4 \
      --min-lines 8 --min-tokens 60 --format "typescript,tsx" \
      --ignore "**/*.test.ts,**/*.test.tsx,**/test/**" \
      --reporters console || exit 1
  ) || fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "pre-push: quality gate FAILED. Fix the issues above, or bypass with 'git push --no-verify'." >&2
  exit 1
fi

echo "pre-push: quality gate passed."
exit 0
