{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.tsx",
    "src/**/*.test.{ts,tsx}",
    "src/test/**",
    "*.config.{ts,mjs}",
    "playwright.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/vite-env.d.ts"],
  "ignoreDependencies": [
    "@fontsource/ibm-plex-mono",
    "@fontsource/ibm-plex-sans",
    "@fontsource/silkscreen",
    "tailwindcss",
    "@lingui/swc-plugin",
    "rollup-plugin-visualizer",
    "pixelarticons"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "off",
    "types": "off",
    "nsExports": "off",
    "nsTypes": "off",
    "enumMembers": "off",
    "duplicates": "off"
  }
}
