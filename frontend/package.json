{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "bun run lint:imports && bun run lint:css && bun run format:check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint:imports": "node ../scripts/check-forbidden-imports.mjs src",
    "lint:css": "node ../scripts/check-arbitrary-typography.mjs src",
    "lint:i18n:format": "node ../scripts/check-i18n-format.mjs",
    "lint:i18n": "node ../scripts/check-i18n-catalog.mjs",
    "lint:tsc": "tsc -b --noEmit",
    "lint:bundle": "vite build && node ../scripts/check-bundle-budget.mjs",
    "lint:biome": "biome lint src",
    "lint:dup": "jscpd src --min-lines 8 --min-tokens 60 --format \"typescript,tsx\" --ignore \"**/*.test.ts,**/*.test.tsx,**/test/**\"",
    "lint:complexity": "eslint -c eslint.complexity.config.mjs src --no-config-lookup",
    "lint:dead": "knip --no-config-hints",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/silkscreen": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@lingui/core": "^6.0.1",
    "@lingui/react": "^6.0.1",
    "@tanstack/react-query": "^5.100.7",
    "@yudiel/react-qr-scanner": "2.5.1",
    "barcode-detector": "3.0.8",
    "cmdk": "1.1.1",
    "ios-haptics": "0.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-router": "^7.14.2",
    "recharts": "^3.8.1",
    "sonner": "2.0.7",
    "tinykeys": "4.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4",
    "@biomejs/biome": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.0.1",
    "@lingui/format-po": "^6.0.1",
    "@lingui/swc-plugin": "6.0.0",
    "@lingui/vite-plugin": "^6.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.7",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "jscpd": "^5.0.10",
    "jsdom": "latest",
    "knip": "^6.17.1",
    "msw": "^2.14.2",
    "rollup-plugin-visualizer": "latest",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
