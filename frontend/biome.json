{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": ["src/**/*.ts", "src/**/*.tsx", "*.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "trailingCommas": "all" }
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "src/test/**"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "complexity": { "noUselessConstructor": "off" }
        }
      }
    }
  ]
}
