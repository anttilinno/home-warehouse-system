# Database Configuration
GO_DATABASE_URL=postgresql://wh:wh@localhost:5432/warehouse_dev?sslmode=disable
DBMATE_DATABASE_URL=postgresql://wh:wh@localhost:5432/warehouse_dev?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION_HOURS=24

# Application Configuration
APP_DEBUG=true
APP_ENV=development

# Import Configuration
IMPORT_UPLOAD_DIR=/tmp/imports
IMPORT_MAX_FILE_SIZE_MB=10
IMPORT_ALLOWED_FORMATS=csv

# Queue Configuration
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_SECONDS=5

# Logging
LOG_LEVEL=info

# Server Configuration
SERVER_PORT=8000
WORKER_HEALTH_PORT=8081

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Authelia (reverse-proxy forward-auth SSO) -- see docs/AUTHELIA.md
# Disabled by default. When enabled, the reverse proxy in front of Authelia
# MUST inject AUTHELIA_SHARED_SECRET as the X-Authelia-Shared-Secret header and
# strip any client-supplied copy. The backend refuses to start with
# AUTHELIA_ENABLED=true and an empty secret.
AUTHELIA_ENABLED=false
AUTHELIA_SHARED_SECRET=
