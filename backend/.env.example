# Database Configuration
# Both server and worker read DATABASE_URL; GO_DATABASE_URL (if set) takes
# precedence — useful when sharing an env file with a non-Go stack whose
# DATABASE_URL points elsewhere.
GO_DATABASE_URL=postgresql://wh:wh@localhost:5432/warehouse_dev?sslmode=disable
DBMATE_DATABASE_URL=postgresql://wh:wh@localhost:5432/warehouse_dev?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
# REQUIRED in production: a random value of at least 32 characters
# (e.g. `openssl rand -base64 48`). The server refuses to start without one
# unless DEBUG=true, in which case an insecure dev-only fallback is used.
JWT_SECRET=
JWT_EXPIRATION_HOURS=24

# Application Configuration
APP_DEBUG=true
# Production is detected via APP_ENV=production OR an https APP_URL.
# This single signal controls the cookie Secure flag and OAuth state cookies.
APP_ENV=development

# Import Configuration
IMPORT_UPLOAD_DIR=/tmp/imports
IMPORT_MAX_FILE_SIZE_MB=10
IMPORT_ALLOWED_FORMATS=csv

# Queue Configuration
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_SECONDS=5

# Logging
LOG_LEVEL=info

# Server Configuration
# SERVER_HOST/SERVER_PORT control the listen address (default 0.0.0.0:8080).
# A bare PORT env var, if set, overrides SERVER_PORT (legacy deployments).
SERVER_PORT=8080
WORKER_HEALTH_PORT=8081
# Global HTTP request body cap in megabytes (default 64)
MAX_BODY_SIZE_MB=64

# CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000
# Frontend origin; included in the CORS allowlist and used for prod detection
APP_URL=http://localhost:3000
# Extra allowed CORS origins, comma-separated. Origins are matched exactly --
# there is NO private-network auto-allow. LAN deployments must list their
# frontend origin here explicitly, e.g.:
# CORS_ALLOWED_ORIGINS=http://192.168.1.50:3000,https://warehouse.example.com
CORS_ALLOWED_ORIGINS=

# Authelia (reverse-proxy forward-auth SSO) -- see docs/AUTHELIA.md
# Disabled by default. When enabled, the reverse proxy in front of Authelia
# MUST inject AUTHELIA_SHARED_SECRET as the X-Authelia-Shared-Secret header and
# strip any client-supplied copy. The backend refuses to start with
# AUTHELIA_ENABLED=true and an empty secret.
AUTHELIA_ENABLED=false
AUTHELIA_SHARED_SECRET=

# Paperless-ngx DMS integration (docs/ROADMAP.md "DMS Migration").
# Key material used to encrypt each workspace's Paperless API token at rest
# (AES-256-GCM; the key is SHA-256-derived, so any length is accepted but use a
# long random value). When empty, token storage is disabled: saving Paperless
# settings with a token returns an error rather than persisting plaintext.
PAPERLESS_TOKEN_KEY=
